# Copy to .env for local development (gitignored). None of these are
# required to run `npm start`/`npm test` — every module falls back to an
# in-memory store when its DB/secret env var is unset. Set them for anything
# beyond local smoke-testing.

# Postgres connection string (Neon / Vercel Postgres). Unset = every module
# runs against its in-memory repo instead — data won't survive a restart.
DATABASE_URL=

# A second, separate database used only by `npm run test:integration`.
# Never point this at the same database as DATABASE_URL — integration tests
# truncate tables between runs. Unset = integration tests are skipped, not
# failed, so `npm test`/CI don't need this.
TEST_DATABASE_URL=

# Session/auth signing secrets. The app falls back to public, hardcoded dev
# secrets (with a console warning) if these are unset — fine for local dev,
# never for anything reachable from the internet. Generate real ones with:
#   openssl rand -hex 32
SESSION_ACCESS_SECRET=
SESSION_REFRESH_SECRET=
AUTH_CHALLENGE_SECRET=
